# Server
NODE_ENV=development
PORT=3000
APP_BASE_URL=https://your-app.ondigitalocean.app

# HubSpot App credentials (from developer.hubspot.com)
HUBSPOT_CLIENT_ID=your_client_id_here
HUBSPOT_CLIENT_SECRET=your_client_secret_here
HUBSPOT_SCOPES=crm.objects.contacts.read crm.objects.companies.read crm.objects.deals.read crm.objects.tickets.read crm.schemas.contacts.read crm.schemas.companies.read crm.schemas.deals.read crm.pipelines.orders.read automation.flows.read settings.users.read oauth

# Token encryption (generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")
TOKEN_ENCRYPTION_KEY=your_32_byte_hex_key_here

# Session secret
SESSION_SECRET=your_session_secret_here

# Database (add when ready)
DATABASE_URL=postgresql://user:password@host:5433/hubaudit

# AI Provider — 'azure' or 'openai'
AI_PROVIDER=azure

# Azure OpenAI (used when AI_PROVIDER=azure)
AZURE_OPENAI_API_KEY=your_azure_key_here
AZURE_OPENAI_ENDPOINT=https://your-resource-name.openai.azure.com
AZURE_OPENAI_DEPLOYMENT=gpt-5.4-mini
AZURE_OPENAI_API_VERSION=2024-08-01-preview

# Standard OpenAI (used when AI_PROVIDER=openai)
OPENAI_API_KEY=

# Model config — change without touching any code
AI_MODEL_NAME=gpt-5.4-mini
AI_MAX_TOKENS=2500
AI_TEMPERATURE=0.3

# Email (Phase 3)
HUBSPOT_EMAIL_TEMPLATE_ID=your_transactional_template_id
REPORT_RECIPIENT_EMAIL=admin@yourcompany.com
REPORT_RECIPIENT_NAME=HubSpot Admin
REPLY_TO_EMAIL=noreply@hubauditai.com

# PDF / Portal
PORTAL_NAME=Vonazon
